# ============================================
# Frontend Environment
# ============================================
NODE_ENV=production

# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api


# ============================================
# Cloudflare Tunnel
# ============================================
# Get this from Cloudflare Zero Trust Dashboard
# Dashboard -> Networks -> Tunnels -> Create a tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here


